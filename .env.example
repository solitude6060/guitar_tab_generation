# Copy to .env for local-only Docker Compose runs.
# Do not commit real secrets.

MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_BASE_URL=https://api.minimax.io

# Keep false for normal development. Set true only on the 4090 host when you
# explicitly want the gpu-ai image to install heavy optional AI packages.
INSTALL_HEAVY_AI=false

# Resource guards. Keep conservative because the RTX 4090 may be shared with
# other local projects.
APP_CPUS=4
APP_MEM_LIMIT=8g
GPU_CPUS=8
GPU_MEM_LIMIT=20g
GPU_SHM_SIZE=2g
OLLAMA_CPUS=6
OLLAMA_MEM_LIMIT=16g
CUDA_VISIBLE_DEVICES=0
PYTORCH_CUDA_ALLOC_CONF=max_split_size_mb:512

# GPU tests and model downloads are opt-in to avoid stealing VRAM or
# bandwidth from other projects.
GPU_TESTS_ENABLED=0
GPU_MIN_FREE_MB=12000
MODEL_SMOKE_DOWNLOAD=0
MODEL_CACHE_DIR=/models
